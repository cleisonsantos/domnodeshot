{
  "manifest_version": 3,
  "name": "DOMnodeshot",
  "version": "1.0.3",
  "description": "Seleciona elementos, captura PNG completo, copia imagem no clique/Enter e baixa com Ctrl; Ctrl+Shift inclui HTML no clipboard.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "tabs",
    "downloads",
    "debugger",
    "clipboardWrite"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-selector": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Ativar/Desativar modo de seleção de elementos"
    }
  }
}
